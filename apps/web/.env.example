NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-output-of-supabase-status
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (no new keys for the web app — GEOCODIO_KEY lives only in the Edge Function)

# Slice 3: read-only on the client — server actions / API routes may use this
# only if we add a proxy endpoint later. Not exposed to the browser.
CONGRESS_GOV_API_KEY=

# Slice 4 ingest keys — server-only, never exposed to the browser.
# Used by ingest scripts in packages/db; documented here for completeness.
OPENSECRETS_API_KEY=
OPENFEC_API_KEY=

# Sentry public DSN for browser + Next server + Edge runtime.
NEXT_PUBLIC_SENTRY_DSN_WEB=

# Slice 5D ingest keys — server-only, never exposed to the browser.
OPENSTATES_API_KEY=
NY_SENATE_API_KEY=
