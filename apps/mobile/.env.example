# Backend URL. Two ways to run (see docs/superpowers/multi-setup-operations.md):
#
# A) Shared hosted Supabase (recommended for multi-machine) — same value on
#    every setup, no host-loopback math:
#      EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
#
# B) Per-machine local Supabase (offline fallback):
#    - 127.0.0.1 works for the iOS Simulator (shares the Mac's network) and for
#      a physical Android device over USB with `adb reverse tcp:54321 tcp:54321`.
#    - ANDROID EMULATOR: 127.0.0.1 is the emulator itself — use the host alias:
#      EXPO_PUBLIC_SUPABASE_URL=http://10.0.2.2:54321
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-output-of-supabase-status

# Google Maps Android API key (Maps SDK for Android enabled). Read by
# app.config.ts and required for the home/district react-native-maps view to
# render on Android — without it the app crashes at mount with
# "API key not found". iOS uses Apple Maps and does not need this.
GOOGLE_MAPS_API_KEY=

# Sentry public DSN for the mobile app (active in dev-client / preview / production builds — NOT Expo Go).
EXPO_PUBLIC_SENTRY_DSN_MOBILE=
