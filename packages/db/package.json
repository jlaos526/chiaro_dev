{
  "name": "@chiaro/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit && tsc -p tsconfig.seed.json",
    "test": "vitest run",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:test": "supabase test db",
    "supabase:gen-types": "supabase gen types typescript --local > src/types.ts",
    "db:seed-officials": "tsx supabase/seed/officials-ingest.ts",
    "db:seed-tiger": "tsx supabase/seed/tiger-ingest.ts",
    "seed:state-officials": "tsx supabase/seed/state-officials-ingest.ts",
    "seed:openstates-v3-fetch": "tsx supabase/seed/openstates-v3-fetch.ts",
    "seed:openstates-v3-cache-prune": "tsx supabase/seed/openstates-v3-cache-prune.ts",
    "seed:openstates-v3-fetch-all": "tsx supabase/seed/openstates-v3-fetch-all.ts",
    "seed:openstates-committees-fetch": "tsx supabase/seed/openstates-committees-fetch.ts",
    "seed:openstates-committees-ingest": "tsx supabase/seed/openstates-committees-ingest.ts",
    "seed:state-bills-votes": "tsx supabase/seed/state-bills-votes-ingest.ts",
    "seed:state-bills-enrich": "tsx supabase/seed/state-bills-enrich.ts",
    "seed:state-metrics-recompute": "tsx supabase/seed/recompute-state-metrics.ts",
    "seed:state-bills-full": "tsx supabase/seed/state-bills-votes-ingest.ts && tsx supabase/seed/state-bills-enrich.ts && tsx supabase/seed/recompute-state-metrics.ts",
    "seed:state-finance": "tsx supabase/seed/state-finance-ingest.ts",
    "seed:state-scorecards": "tsx supabase/seed/state-scorecards-ingest.ts",
    "seed:state-community": "tsx supabase/seed/state-community-ingest.ts",
    "seed:state-ethics": "tsx supabase/seed/state-ethics-ingest.ts",
    "seed:federal-town-halls-mobilize": "tsx supabase/seed/federal-community-mobilize-ingest.ts",
    "seed:federal-ptrs": "tsx supabase/seed/federal-ptrs-ingest.ts",
    "seed:federal-fds": "tsx supabase/seed/federal-fds-ingest.ts",
    "seed:issue-catalog": "tsx supabase/seed/issue-catalog-ingest.ts",
    "db:seed-unitedstates": "tsx supabase/seed/unitedstates-legislators-ingest.ts",
    "db:seed-bills-votes": "tsx supabase/seed/bills-votes-ingest.ts",
    "db:seed-scorecards": "tsx supabase/seed/scorecards/index.ts",
    "db:seed-finance": "tsx supabase/seed/finance-ingest.ts",
    "db:seed-salary-residency": "tsx supabase/seed/salary-residency-ingest.ts",
    "db:seed-town-halls": "tsx supabase/seed/town-halls-ingest.ts",
    "db:seed-stock-watcher": "tsx supabase/seed/stock-watcher-ingest.ts",
    "db:recompute-metrics": "tsx supabase/seed/recompute-metrics.ts",
    "diagnose:state-leg-district-format": "tsx supabase/seed/diagnostics/state-leg-district-format-check.ts",
    "functions:serve": "supabase functions serve --env-file ../../.env.local"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.0",
    "cheerio": "^1.2.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "shapefile": "^0.6.6",
    "undici": "^6.19.0",
    "unzipper": "^0.12.3",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.0",
    "@types/unzipper": "^0.10.10",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
