# Local Supabase (defaults from `supabase start`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-output-of-supabase-status
# Service-role key — required by domain-package integration tests (officials,
# location, bills, profile). Pull from `supabase status --output env --workdir packages/db`.
SUPABASE_SERVICE_ROLE_KEY=replace-with-output-of-supabase-status
# Direct DB URL — read by every seed script under `packages/db/supabase/seed/`.
# Defaults to local Supabase if unset.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Server-only secret — used by Edge Function calibrate-location.
# Get a key from https://www.geocod.io (free 2,500/day).
GEOCODIO_KEY=

# Congress.gov API key for officials ingest (slice 3).
# Free signup: https://api.data.gov/signup/
# Used by `pnpm seed:officials`. Server-side only — never exposed to clients.
CONGRESS_GOV_API_KEY=

# OpenSecrets API key for campaign finance ingest (slice 4).
# Free signup: https://www.opensecrets.org/api/admin/index.php?function=signup
# Free tier: 200 calls/day. Used by `seed/finance-ingest.ts`. Server-side only.
OPENSECRETS_API_KEY=

# OpenFEC API key for campaign finance ingest fallback (slice 4).
# Free signup: https://api.open.fec.gov/developers/
# Used by `seed/finance-ingest.ts` for FEC filings. Server-side only.
OPENFEC_API_KEY=
# GEOCODIO_KEY already set above (slice 2)
# CONGRESS_GOV_API_KEY already set above (slice 3)

# Optional target bioguide for `pnpm seed:audit-fixture-attach`. Defaults to P000197.
AUDIT_TARGET_BIOGUIDE=

# Sentry — error reporting. DSNs are public; auth token is secret.
SENTRY_AUTH_TOKEN=
SENTRY_DSN_EDGE=

# NY Senate API key for sub-slice 5D state-bills enrichment. Free signup at
# legislation.nysenate.gov/keyOptions. Used by `seed/state-bills/enrich-ny.ts`.
# Server-side only — never exposed to the browser. Adapter skips gracefully when unset.
NY_SENATE_API_KEY=
