{
  "name": "chiaro",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:start": "pnpm --filter @chiaro/db supabase:start",
    "db:stop": "pnpm --filter @chiaro/db supabase:stop",
    "db:reset": "pnpm --filter @chiaro/db supabase:reset",
    "db:test": "pnpm --filter @chiaro/db supabase:test",
    "db:gen-types": "pnpm --filter @chiaro/db supabase:gen-types",
    "db:check-types-drift": "pnpm db:gen-types && git diff --exit-code packages/db/src/types.ts",
    "seed:officials": "pnpm --filter @chiaro/db db:seed-officials",
    "seed:state-officials": "pnpm --filter @chiaro/db seed:state-officials",
    "seed:tiger": "pnpm --filter @chiaro/db db:seed-tiger",
    "seed:unitedstates": "pnpm --filter @chiaro/db db:seed-unitedstates",
    "seed:bills-votes": "pnpm --filter @chiaro/db db:seed-bills-votes",
    "seed:scorecards": "pnpm --filter @chiaro/db db:seed-scorecards",
    "seed:finance": "pnpm --filter @chiaro/db db:seed-finance",
    "seed:salary-residency": "pnpm --filter @chiaro/db db:seed-salary-residency",
    "seed:town-halls": "pnpm --filter @chiaro/db db:seed-town-halls",
    "seed:stock-watcher": "pnpm --filter @chiaro/db db:seed-stock-watcher",
    "seed:issue-catalog": "pnpm --filter @chiaro/db seed:issue-catalog",
    "seed:openstates-v3-fetch": "pnpm --filter @chiaro/db seed:openstates-v3-fetch",
    "seed:openstates-v3-fetch-all": "pnpm --filter @chiaro/db seed:openstates-v3-fetch-all",
    "seed:openstates-v3-cache-prune": "pnpm --filter @chiaro/db seed:openstates-v3-cache-prune",
    "seed:openstates-committees-fetch": "pnpm --filter @chiaro/db seed:openstates-committees-fetch",
    "seed:openstates-committees-ingest": "pnpm --filter @chiaro/db seed:openstates-committees-ingest",
    "seed:state-bills-votes": "pnpm --filter @chiaro/db seed:state-bills-votes",
    "seed:state-bills-enrich": "pnpm --filter @chiaro/db seed:state-bills-enrich",
    "seed:state-bills-full": "pnpm --filter @chiaro/db seed:state-bills-full",
    "seed:state-metrics-recompute": "pnpm --filter @chiaro/db seed:state-metrics-recompute",
    "seed:state-finance": "pnpm --filter @chiaro/db seed:state-finance",
    "seed:state-scorecards": "pnpm --filter @chiaro/db seed:state-scorecards",
    "seed:state-community": "pnpm --filter @chiaro/db seed:state-community",
    "seed:state-ethics": "pnpm --filter @chiaro/db seed:state-ethics",
    "seed:federal-town-halls-mobilize": "pnpm --filter @chiaro/db seed:federal-town-halls-mobilize",
    "seed:federal-ptrs": "pnpm --filter @chiaro/db seed:federal-ptrs",
    "seed:federal-fds": "pnpm --filter @chiaro/db seed:federal-fds",
    "recompute:metrics": "pnpm --filter @chiaro/db db:recompute-metrics",
    "seed:slice-4-full": "pnpm seed:unitedstates && pnpm seed:bills-votes && pnpm seed:scorecards && pnpm seed:finance && pnpm seed:salary-residency && pnpm seed:town-halls && pnpm seed:stock-watcher && pnpm recompute:metrics",
    "seed:state-full": "pnpm seed:state-officials && pnpm seed:openstates-v3-fetch-all && pnpm seed:state-bills-votes && pnpm seed:state-bills-enrich && pnpm seed:state-metrics-recompute && pnpm seed:state-community && pnpm seed:state-ethics"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "~19.1.17",
      "@types/react-dom": "~19.1.10"
    }
  }
}
