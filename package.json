{
  "name": "chiaro",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:start": "pnpm --filter @chiaro/db supabase:start",
    "db:stop": "pnpm --filter @chiaro/db supabase:stop",
    "db:reset": "pnpm --filter @chiaro/db supabase:reset",
    "db:test": "pnpm --filter @chiaro/db supabase:test",
    "db:gen-types": "pnpm --filter @chiaro/db supabase:gen-types",
    "db:check-types-drift": "pnpm db:gen-types && git diff --exit-code packages/db/src/types.ts",
    "seed:officials": "pnpm --filter @chiaro/db db:seed-officials",
    "seed:tiger": "pnpm --filter @chiaro/db db:seed-tiger",
    "seed:unitedstates": "pnpm --filter @chiaro/db db:seed-unitedstates",
    "seed:bills-votes": "pnpm --filter @chiaro/db db:seed-bills-votes",
    "seed:scorecards": "pnpm --filter @chiaro/db db:seed-scorecards",
    "seed:finance": "pnpm --filter @chiaro/db db:seed-finance",
    "seed:salary-residency": "pnpm --filter @chiaro/db db:seed-salary-residency",
    "seed:town-halls": "pnpm --filter @chiaro/db db:seed-town-halls",
    "seed:stock-watcher": "pnpm --filter @chiaro/db db:seed-stock-watcher",
    "seed:issue-catalog": "pnpm --filter @chiaro/db seed:issue-catalog",
    "recompute:metrics": "pnpm --filter @chiaro/db db:recompute-metrics",
    "seed:slice-4-full": "pnpm seed:unitedstates && pnpm seed:bills-votes && pnpm seed:scorecards && pnpm seed:finance && pnpm seed:salary-residency && pnpm seed:town-halls && pnpm seed:stock-watcher && pnpm recompute:metrics"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "~19.1.17",
      "@types/react-dom": "~19.1.10"
    }
  }
}
